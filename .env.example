# Marketing Command Center — Environment Variables
# Copy to .env and fill in all values before running anything.
# Never commit .env to the repo.

# Database
DATABASE_URL=                          # Railway PostgreSQL connection string (must have pgvector enabled)

# X / Twitter API (bullseye account — OAuth 1.0a)
X_API_KEY=                             # Consumer key from developer.x.com
X_API_SECRET=                          # Consumer secret
X_ACCESS_TOKEN=                        # Access token (bullseye account)
X_ACCESS_TOKEN_SECRET=                 # Access token secret
X_LIST_ID=                             # Numeric ID of gauntlet_graduates list

# Slack
SLACK_BOT_TOKEN=                       # xoxb-... (Bot User OAuth Token)
SLACK_CHANNEL_IDS=                     # Comma-separated channel IDs: #claude-maxxing, #industry-news, #ai-first-methodologies
SLACK_ALERT_CHANNEL=                   # Slack channel ID for pipeline alerts (bot posts via chat.postMessage, no webhook needed)

# OpenAI (embeddings)
OPENAI_API_KEY=                        # For text-embedding-3-small

# Anthropic (summarization)
ANTHROPIC_API_KEY=                     # For Claude Sonnet

# Frontend
NEXT_PUBLIC_API_URL=                   # Railway backend URL (e.g. https://mcc-backend.railway.app)
